# ── Container registry ─────────────────────────────────────────
# Your AWS account: aws sts get-caller-identity --query Account --output text
ECR_REGISTRY=123456789012.dkr.ecr.ap-south-1.amazonaws.com

# Image tags — set by CI/CD to the git SHA of each deploy
BACKEND_TAG=latest
CLIENT_TAG=latest
ADMIN_TAG=latest

# ── Client frontend ────────────────────────────────────────────
# Must match the public URL of the backend
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# ── Backend ────────────────────────────────────────────────────
DB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/everest?retryWrites=true&w=majority
CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
AUTH_COOKIE_NAME=auth_token
REFRESH_COOKIE_NAME=refresh_token

OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=3
OTP_LENGTH=6

USE_MSG91_OTP=false
MSG91_AUTH_KEY=
MSG91_TEMPLATE_LOGIN_OTP=
MSG91_TEMPLATE_SIGNUP_OTP=
MSG91_TEMPLATE_PASSWORD_RESET=
MSG91_TEMPLATE_RIDER_ASSIGNED_RIDER=
MSG91_TEMPLATE_RIDER_ASSIGNED_CLIENT=
MSG91_TEMPLATE_REPORT_READY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/oauth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

APPLE_CALLBACK_URL=https://api.yourdomain.com/auth/oauth/apple/callback
OAUTH_SUCCESS_REDIRECT=https://yourdomain.com/

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
